.vscode/settings.json

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
nightly.log

# local env files
.env*.local
.env

# vercel
.vercel

# distribution packages
/dist

